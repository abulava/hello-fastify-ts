{
  "name": "hello-fastify-ts",
  "version": "0.1.0",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "type": "module",
  "main": "app.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "c8 node --test --import tsx \"test/**/*.ts\"",
    "start": "NODE_ENV=production fastify start -l info dist/app.js",
    "prebuild": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "NODE_ENV=production npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc",
    "dev": "fastify start -w -l info -P src/app.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/react": "^1.2.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/vite": "^9.1.1",
    "fastify": "^5.10.0",
    "fastify-cli": "^8.0.0",
    "fastify-plugin": "^5.0.0",
    "history": "^5.3.0",
    "minipass": "^7.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0",
    "valtio": "^2.3.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "c8": "^11.0.0",
    "fastify-tsconfig": "^3.0.0",
    "oxlint": "^1.74.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "~5.9.2",
    "vite": "^8.1.4"
  },
  "engines": {
    "node": "22.x"
  }
}
